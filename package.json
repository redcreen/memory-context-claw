{
  "name": "unified-memory-core",
  "version": "0.1.0",
  "description": "OpenClaw context-engine plugin for memory reranking and context assembly",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "test": "node --test",
    "smoke": "node scripts/smoke-assemble.js",
    "smoke:llm": "node scripts/smoke-assemble.js --preset llm-rerank --llm-rerank",
    "smoke:compare": "node scripts/compare-presets.js",
    "smoke:eval": "node scripts/eval-smoke-cases.js",
    "smoke:eval:critical": "node scripts/eval-smoke-cases.js --categories user-facts,rules",
    "eval": "node scripts/eval-cases.js",
    "eval:perf": "node scripts/eval-performance.js",
    "eval:memory-search:cases": "node scripts/eval-memory-search-cases.js",
    "eval:memory-search:governance": "node scripts/run-memory-search-governance.js",
    "eval:smoke-promotion": "node scripts/eval-smoke-promotion.js",
    "eval:agent": "node scripts/agent-regression.js",
    "eval:agent:critical": "node scripts/agent-regression.js --only food-preference-latest,identity-preferred-name",
    "eval:agent:stable-facts": "node scripts/agent-regression.js --only birthday-solar,birthday-lunar,daughter-profile,son-profile,children-overview,identity-birthyear-dual",
    "eval:agent:facts": "node scripts/agent-regression.js --cases evals/fact-growth-cases.json",
    "eval:hot": "node scripts/agent-regression.js",
    "eval:hot:critical": "node scripts/agent-regression.js --only food-preference-latest,identity-preferred-name",
    "eval:hot:stable-facts": "node scripts/agent-regression.js --only birthday-solar,birthday-lunar,daughter-profile,son-profile,children-overview,identity-birthyear-dual",
    "eval:hot:facts": "node scripts/agent-regression.js --cases evals/fact-growth-cases.json",
    "eval:toggle": "node scripts/compare-enabled-disabled.js",
    "eval:memory-search": "node scripts/eval-memory-search-params.js",
    "memory:distill": "node scripts/distill-session-memory.js",
    "memory:apply-daily": "node scripts/apply-daily-memory.js",
    "memory:export-pending": "node scripts/export-pending-memory.js",
    "memory:audit-formal": "node scripts/audit-formal-memory.js",
    "memory:govern-safe": "node scripts/apply-safe-formal-governance.js",
    "memory:audit-session-exit": "node scripts/audit-session-memory-exit.js",
    "memory:audit-conflicts": "node scripts/audit-fact-conflicts.js",
    "memory:audit-duplicates": "node scripts/audit-fact-duplicates.js",
    "memory:governance-cycle": "node scripts/run-governance-cycle.js",
    "umc:cli": "node scripts/unified-memory-core-cli.js",
    "umc:daily-reflection": "node scripts/run-daily-reflection.js",
    "umc:lifecycle": "node scripts/run-learning-lifecycle.js",
    "umc:policy-loop": "node scripts/run-policy-adaptation-loop.js",
    "umc:acceptance": "node scripts/run-stage3-stage4-acceptance.js",
    "umc:openclaw-itest": "node scripts/run-openclaw-cli-integration.js",
    "umc:independent-review": "node scripts/run-independent-execution-review.js",
    "verify": "node scripts/verify-suite.js",
    "deploy:local": "node scripts/deploy-openclaw-local.js",
    "runtime:check": "node scripts/configure-local-runtime.js --check",
    "runtime:apply": "node scripts/configure-local-runtime.js",
    "runtime:remove": "node scripts/configure-local-runtime.js --remove",
    "config:apply": "node scripts/apply-openclaw-config.js"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-engine",
    "memory",
    "rerank",
    "retrieval"
  ],
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  }
}
